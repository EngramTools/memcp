# Created by https://www.toptal.com/developers/gitignore/api/macos,rust,visualstudiocode
# Edit at https://www.toptal.com/developers/gitignore?templates=macos,rust,visualstudiocode

### macOS ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### macOS Patch ###
# iCloud generated files
*.icloud

### Rust ###
# Generated by Cargo — compiled files and executables
debug/
target/

# NOTE: Cargo.lock is intentionally NOT ignored here because this is an executable
# workspace (not a library). Cargo.lock should be committed for reproducible builds.
# See: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these (debugging symbols)
*.pdb

### VisualStudioCode ###
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

### VisualStudioCode Patch ###
.history
.ionide

# End of toptal template

# Project-specific

# SQLite database files (memcp runtime state — never commit live DB)
*.db
*.db-shm
*.db-wal

# Environment / secrets
.env
.env.*

# FastEmbed model cache (large binary model files downloaded at runtime)
.fastembed_cache/

# Benchmark / load test data (eval corpora + regenerable run artifacts)
data/longmemeval/
data/locomo/
data/results/
data/benchmark_history.jsonl
data/migration_*_report.jsonl

# Agent system and AI tooling state (local, machine-specific)
.agents/
.claude/
.planning/

# Python tooling cache (used by QA scripts)
.ruff_cache/

# Local config override (only the example should be tracked)
memcp.toml

# Log files
*.log

# CLAUDE.md is a local dev convention file, not part of the public repo
CLAUDE.md

# One-off analysis artifacts
engram-analysis.html
engram-analysis.md
